# Copy this file to .env (or export these as real environment variables)
# and fill in the API key/secret generated from your Binance Futures Testnet account.

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Optional override; defaults to the Futures Testnet already.
BINANCE_BASE_URL=https://testnet.binancefuture.com
